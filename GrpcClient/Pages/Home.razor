@page "/"
@using AntDesign
@using Server_Shared.model

<PageTitle>Index</PageTitle>

<!-- Search & Add -->
<div style="display:flex; align-items:center; gap:12px; margin-bottom:16px;">
    <Select Style="width:200px"
            Placeholder="-- Chon ma SV --"
            TItem="ModelSinhVien"
            TItemValue="string"
            DataSource="listselect.AsEnumerable()"
            LabelName="@nameof(ModelSinhVien.MaSinhVien)"
            ValueName="@nameof(ModelSinhVien.MaSinhVien)"
            OnSelectedItemChanged="@(async (ModelSinhVien sv) => await HandlerSearch(sv?.MaSinhVien ?? ""))"
            AllowClear />
    <Button Type="@ButtonType.Primary"
            Icon="@IconType.Outline.Plus"
            OnClick="HandleClickThem">
        Them
    </Button>
</div>

<!-- Form -->
@if (hideForm)
{
    <Card Style="margin-bottom:24px;">
        <TitleTemplate>
            <Text Strong Style="font-size:18px;">
                @(createOrUpdate == true ? "THEM SINH VIEN" : "SUA SINH VIEN")
            </Text>
        </TitleTemplate>
        <Body>
            <Form Model="model"
                  OnFinish="HandleValidSubmit"
                  Layout="@FormLayout.Vertical">
                <Row Gutter="16">
                    <AntDesign.Col Span="12">
                        <FormItem Label="Ten Sinh Vien *">
                            <Input @bind-Value="@context.Ten" Placeholder="Nhap ten sinh vien" />
                        </FormItem>
                    </AntDesign.Col>
                    <AntDesign.Col Span="12">
                        <FormItem Label="Ngay Sinh *">
                            <DatePicker @bind-Value="@context.NgaySinh" Style="width:100%" />
                        </FormItem>
                    </AntDesign.Col>
                    <AntDesign.Col Span="12">
                        <FormItem Label="Dia Chi *">
                            <Input @bind-Value="@context.DiaChi" Placeholder="Nhap dia chi" />
                        </FormItem>
                    </AntDesign.Col>
                    <AntDesign.Col Span="12">
                        <FormItem Label="Lop Hoc *">
                            <Select Style="width:100%"
                                    Placeholder="-- Chon lop --"
                                    TItem="ModelLopHoc"
                                    TItemValue="int"
                                    DataSource="listLopHoc.AsEnumerable()"
                                    LabelName="@nameof(ModelLopHoc.TenLopHoc)"
                                    ValueName="@nameof(ModelLopHoc.Id)"
                                    @bind-Value="@context.LopHoc.Id" />
                        </FormItem>
                    </AntDesign.Col>
                </Row>
                <div style="display:flex; gap:8px; justify-content:flex-end; margin-top:8px;">
                    <Button Type="@ButtonType.Primary"
                            HtmlType="submit"
                            Icon="@IconType.Outline.Save">
                        Save
                    </Button>
                    <Button OnClick="HandleReset"
                            Icon="@IconType.Outline.Reload">
                        Reset
                    </Button>
                </div>
            </Form>
        </Body>
    </Card>
}

<!-- Table -->
<Table DataSource="list.AsEnumerable()" TItem="ModelSinhVien" Bordered>
    <Column Title="Ma Sinh Vien" @bind-Field="@context.MaSinhVien" TData="string" />
    <Column Title="Ten Sinh Vien" @bind-Field="@context.Ten" TData="string" />
    <Column Title="Ngay Sinh" @bind-Field="@context.NgaySinh" TData="DateTime">
        @context.NgaySinh.ToString("dd/MM/yyyy")
    </Column>
    <Column Title="Dia Chi" @bind-Field="@context.DiaChi" TData="string" />
    <Column Title="Lop Hoc" TData="string">
        @context.LopHoc?.TenLopHoc
    </Column>
    <ActionColumn Title="Hanh Dong">
        <Space>
            <SpaceItem>
                <Button Type="@ButtonType.Default"
                        Icon="@IconType.Outline.Edit"
                        OnClick="@(() => HandleClickSua(context.Id))">
                    Sua
                </Button>
            </SpaceItem>
            <SpaceItem>
                <Popconfirm Title="Ban co chac muon xoa?"
                            OnConfirm="@(() => HandlerClickXoa(context.Id))"
                            OkText="Xoa"
                            CancelText="Huy">
                    <Button Danger Icon="@IconType.Outline.Delete">Xoa</Button>
                </Popconfirm>
            </SpaceItem>
        </Space>
    </ActionColumn>
</Table>